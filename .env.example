RESEND_API_KEY=

# Sender address configured in Resend. For production, use a verified domain.
CONTACT_EMAIL_FROM="CV Website <onboarding@resend.dev>"

# Recipient address. Defaults to profile.email if omitted.
CONTACT_EMAIL_TO=quangngoc201197@gmail.com

# Optional GitHub backup defaults for /skill-roadmap.
# Keep the token server-side only; the app does not expose it to the browser.
GITHUB_BACKUP_TOKEN=
GITHUB_BACKUP_REPO_URL=
GITHUB_BACKUP_BRANCH=cv-dev
GITHUB_BACKUP_PATH=src/data/skill-roadmap-progress.json
GITHUB_BACKUP_COMMIT_MESSAGE="Backup skill roadmap progress"

# Server-side AI config for generating task flashcards.
# Compatible with OpenAI-style /chat/completions endpoints.
AI_FLASHCARD_API_KEY=
AI_FLASHCARD_BASE_URL=https://api.kilo.ai/api/gateway
AI_FLASHCARD_MODEL=

# Server-side Kilo AI config for Markdown comment "Hỏi AI".
# The API key stays server-side and is never shown in the browser.
AI_COMMENT_KILO_API_KEY=
AI_COMMENT_KILO_BASE_URL=https://api.kilo.ai/api/gateway
AI_COMMENT_KILO_MODEL=

# Server-side AI config for automatically generating parent task notes.
# This feature is opt-in to prevent page views from calling AI unexpectedly.
AI_TASK_NOTE_ENABLED=false
AI_TASK_NOTE_API_KEY=
AI_TASK_NOTE_BASE_URL=https://api.kilo.ai/api/gateway
AI_TASK_NOTE_MODEL=

# Required before using any AI feature backed by server-side env API keys.
# Users must enter this password in the UI to confirm each env-backed AI request.
AI_ENV_CONFIRM_PASSWORD=
