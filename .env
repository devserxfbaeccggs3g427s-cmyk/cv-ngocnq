AI_TASK_NOTE_MODEL=deepseek/deepseek-v4-flash

# Required before using any AI feature backed by server-side env API keys.
# Users must enter this password in the UI to confirm each env-backed AI request.
AI_ENV_CONFIRM_PASSWORD=123