# Server-side AI config for automatically generating parent task notes.
# This feature is opt-in to prevent page views from calling AI unexpectedly.
AI_TASK_NOTE_ENABLED=true
AI_TASK_NOTE_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJlbnYiOiJwcm9kdWN0aW9uIiwia2lsb1VzZXJJZCI6IjczZGQ5MGUxLTU3NTctNDRiYy04Yjk0LTc0ZTdlMTExZWNiNiIsImFwaVRva2VuUGVwcGVyIjpudWxsLCJ2ZXJzaW9uIjozLCJpYXQiOjE3ODE3NTE3MTQsImV4cCI6MTkzOTQzMTcxNH0.sMIjQEUuFH-sHEGHEVDHqMpyKxpqZrPwEc-HYZuK2sE
